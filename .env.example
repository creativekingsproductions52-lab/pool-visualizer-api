# ─── Pool Visualizer — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to Git.

# Google Cloud Platform API key
# Enable: Geocoding API, Maps Static API, Map Tiles API (Photorealistic 3D Tiles)
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter API key (starts with sk-or-...)
# https://openrouter.ai → Keys → Create Key
# Add at least $20 in credits to cover ~6 test generations
OPENROUTER_API_KEY=sk-or-your_key_here

# Server port (default 3001)
PORT=3001
